# Three Worlds — Environment Variables
# Copy to .env and fill in values

# API
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=your-secret-key-here

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/threeworlds
REDIS_URL=redis://localhost:6379/0

# AI
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=  # Optional, for embeddings

# ECHA Data
ECHA_DB_PATH=./data/echa_registered_substances.db

# Payments
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-key

# Storage
S3_BUCKET=threeworlds-documents
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
